---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const features = [
  {
    icon: '🗺️',
    title: 'ルート計画 & ナビゲーション',
    description: 'AIがあなたの体力レベルに合わせた最適ルートを提案。動的な難易度評価、エスケープルート表示、天候変化時の自動ルート変更で安全な登山をサポートします。',
  },
  {
    icon: '📍',
    title: 'マップ & GPS',
    description: 'リアルタイム位置追跡、オフライン地図対応、3D地形表示、GPSノイズフィルタリングで、電波の届かない山中でも正確なナビゲーションを提供します。',
  },
  {
    icon: '🆘',
    title: '安全 & 緊急対応',
    description: 'ワンタップSOS発信、危険区域アラート、落雷・雪崩リスク表示、高山病モニター。万が一の事態にも迅速に対応できます。',
  },
  {
    icon: '🌤️',
    title: '山岳気象',
    description: '山岳特化の天気予報、気圧計連携、雨雲レーダー、天候に応じた装備推奨リンクで、変わりやすい山の天気に備えましょう。',
  },
  {
    icon: '💪',
    title: 'フィットネス & 健康',
    description: 'カロリー消費追跡、疲労度モデル、水分補給リマインダー、ペース分析。あなたの体調をリアルタイムでモニタリングします。',
  },
  {
    icon: '📝',
    title: '記録 & 共有',
    description: 'GPXインポート/エクスポート、自動山行レポート生成、タイムラプス動画、ヒートマップ、PDF出力で登山の思い出を残しましょう。',
  },
  {
    icon: '👥',
    title: 'コミュニティ',
    description: 'リアルタイム位置共有、グループダッシュボード、パートナーマッチング、混雑情報で仲間との登山をもっと楽しく安全に。',
  },
  {
    icon: '🧠',
    title: 'AI/ML エンジン',
    description: 'AI ルート推薦、ML疲労予測、MLリスクアセスメント、山岳チャットボット。最新の機械学習であなたの登山を最適化します。',
  },
];

const highlights = [
  {
    value: '130+',
    label: 'モジュール',
    description: 'PWAとして構築された大規模アプリケーション',
  },
  {
    value: '333',
    label: 'テスト',
    description: '品質を保証する包括的なテストスイート',
  },
  {
    value: '8',
    label: '機能カテゴリ',
    description: '登山のあらゆるシーンをカバー',
  },
];

const techStack = [
  { name: 'PWA', description: 'プログレッシブWebアプリ' },
  { name: 'Firebase', description: 'バックエンド・認証・データベース' },
  { name: 'AI/ML', description: 'ルート推薦・リスク評価・疲労予測' },
  { name: 'iOS / Android', description: 'ネイティブアプリ開発予定' },
];
---

<Layout
  title="YAMAGO - 山へ行く人のためのアプリ"
  description="YAMAGO（ヤマゴ）は、ルート計画、GPS追跡、緊急SOS、山岳気象、AI分析など130以上のモジュールを搭載した総合登山プラットフォームです。山登りをもっと楽しく、もっと安全に。"
>
  <Header currentPath="/products/yamago" />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content">
            <span class="badge">🏔️ 総合登山プラットフォーム</span>
            <h1>YAMAGO</h1>
            <p class="tagline">山へ行く人のためのアプリ</p>
            <p class="subtitle">山登りをもっと楽しく、もっと安全に</p>
            <p class="description">
              ルート計画からGPS追跡、緊急SOS、山岳気象、フィットネス管理、AI分析まで、
              登山のすべてをカバーする総合プラットフォーム。130以上のモジュールと
              333のテストで構築された、信頼性の高いPWAアプリです。
            </p>
            <div class="hero-buttons">
              <a href="#features" class="btn btn-primary">
                機能を見る
              </a>
            </div>
          </div>

          <div class="hero-image">
            <div class="mountain-mockup">
              <div class="mountain-scene">
                <div class="sky">
                  <div class="cloud cloud-1"></div>
                  <div class="cloud cloud-2"></div>
                  <div class="cloud cloud-3"></div>
                </div>
                <svg class="mountain-svg" viewBox="0 0 420 280" preserveAspectRatio="xMidYMax slice">
                  <!-- Back mountain -->
                  <path d="M -30 280 L 80 85 Q 100 55 120 80 L 160 120 Q 175 100 190 108 L 270 280 Z" fill="#6b8e73"/>
                  <path d="M 80 85 Q 100 55 120 80 L 112 92 Q 100 68 88 88 Z" fill="white" opacity="0.7"/>
                  <!-- Mid mountain (tallest) -->
                  <path d="M 100 280 L 210 40 Q 230 10 250 35 L 275 65 Q 290 50 300 58 L 380 280 Z" fill="#4a7c59"/>
                  <path d="M 210 40 Q 230 10 250 35 L 242 50 Q 230 22 218 45 Z" fill="white" opacity="0.85"/>
                  <path d="M 275 65 Q 282 55 290 58 L 286 67 Z" fill="white" opacity="0.5"/>
                  <!-- Front mountain -->
                  <path d="M 260 280 L 350 90 Q 370 60 390 85 L 415 115 Q 425 105 435 110 L 460 280 Z" fill="#3d6b4e"/>
                  <path d="M 350 90 Q 370 60 390 85 L 382 98 Q 370 70 358 93 Z" fill="white" opacity="0.7"/>
                  <!-- Tree silhouettes -->
                  <path d="M 25 268 L 30 245 L 27 248 L 33 230 L 30 233 L 35 220 L 40 233 L 37 230 L 43 248 L 40 245 L 45 268 Z" fill="#2d5a3a" opacity="0.7"/>
                  <path d="M 55 273 L 60 252 L 57 255 L 63 240 L 60 243 L 65 232 L 70 243 L 67 240 L 73 255 L 70 252 L 75 273 Z" fill="#2d5a3a" opacity="0.6"/>
                  <path d="M 85 275 L 88 260 L 86 262 L 90 253 L 93 262 L 91 260 L 94 275 Z" fill="#2d5a3a" opacity="0.5"/>
                  <path d="M 395 270 L 400 252 L 397 255 L 403 240 L 400 243 L 405 232 L 410 243 L 407 240 L 413 255 L 410 252 L 415 270 Z" fill="#1e4a2e" opacity="0.7"/>
                  <path d="M 425 275 L 428 262 L 426 264 L 430 256 L 433 264 L 431 262 L 434 275 Z" fill="#1e4a2e" opacity="0.5"/>
                  <!-- Trail -->
                  <path d="M 25 260 Q 70 230 110 200 Q 150 170 190 145 Q 230 120 260 95 Q 285 75 310 50" fill="none" stroke="#ef4444" stroke-width="3" stroke-dasharray="8 4" stroke-linecap="round"/>
                  <circle cx="25" cy="260" r="5" fill="#22c55e"/>
                  <circle cx="190" cy="145" r="4" fill="#f59e0b"/>
                  <circle cx="310" cy="50" r="5" fill="#ef4444"/>
                </svg>
                <div class="app-overlay">
                  <div class="app-stat">
                    <span class="app-stat-value">2,847m</span>
                    <span class="app-stat-label">標高</span>
                  </div>
                  <div class="app-status">
                    <span class="status-dot"></span>
                    <span>GPS追跡中</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Highlights -->
    <section class="section highlights">
      <div class="container">
        <div class="highlights-grid">
          {highlights.map(item => (
            <div class="highlight-card">
              <div class="highlight-value">{item.value}</div>
              <div class="highlight-label">{item.label}</div>
              <p>{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="section features">
      <div class="container">
        <div class="section-title">
          <h2>機能</h2>
          <p>登山のあらゆるシーンをカバーする8つの機能カテゴリ</p>
        </div>

        <div class="features-grid">
          {features.map(feature => (
            <div class="feature-card">
              <div class="feature-icon">{feature.icon}</div>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="section tech">
      <div class="container">
        <div class="section-title">
          <h2>技術スタック</h2>
          <p>信頼性の高いアーキテクチャ</p>
        </div>

        <div class="tech-grid">
          {techStack.map(tech => (
            <div class="tech-card">
              <h4>{tech.name}</h4>
              <p>{tech.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="section architecture">
      <div class="container">
        <div class="section-title">
          <h2>アーキテクチャ</h2>
          <p>130以上のモジュールで構成されたPWAプラットフォーム</p>
        </div>

        <div class="arch-diagram">
          <div class="arch-box main">
            <div class="arch-title">YAMAGO (PWA)</div>
            <div class="arch-children">
              <div class="arch-box">
                <div class="arch-title">フロントエンド</div>
                <div class="arch-items">
                  <span>ルート計画</span>
                  <span>3Dマップ</span>
                  <span>オフライン対応</span>
                </div>
              </div>
              <div class="arch-box">
                <div class="arch-title">AI/ML エンジン</div>
                <div class="arch-items">
                  <span>ルート推薦</span>
                  <span>疲労予測</span>
                  <span>リスク評価</span>
                </div>
              </div>
              <div class="arch-box">
                <div class="arch-title">バックエンド</div>
                <div class="arch-items">
                  <span>Firebase</span>
                  <span>GPS処理</span>
                  <span>気象データ</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section cta">
      <div class="container">
        <div class="cta-content">
          <h2>YAMAGOで山登りをもっと楽しく</h2>
          <p>
            AI搭載の総合登山プラットフォームで、
            安全で充実した山行を体験しましょう。
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 4rem 0 6rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, #f0fdf4 100%);
  }

  :global([data-theme="dark"]) .hero {
    background: linear-gradient(180deg, var(--color-bg) 0%, #0a1f0a 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #16a34a, #15803d);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: 4rem;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, #16a34a, #ca8a04);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .tagline {
    font-size: 1.5rem;
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: #16a34a;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .description {
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero .btn-primary {
    background: linear-gradient(135deg, #16a34a, #15803d);
  }

  .hero .btn-primary:hover {
    background: linear-gradient(135deg, #15803d, #166534);
  }

  /* Mountain Mockup */
  .hero-image {
    display: flex;
    justify-content: center;
  }

  .mountain-mockup {
    width: 100%;
    max-width: 420px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
  }

  .mountain-scene {
    position: relative;
    width: 100%;
    height: 280px;
    background: linear-gradient(180deg, #7dd3fc 0%, #bae6fd 40%, #e0f2fe 70%);
    overflow: hidden;
  }

  :global([data-theme="dark"]) .mountain-scene {
    background: linear-gradient(180deg, #1e3a5f 0%, #0f2942 40%, #0c1e33 70%);
  }

  .sky {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
  }

  .cloud {
    position: absolute;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 50px;
    height: 16px;
  }

  :global([data-theme="dark"]) .cloud {
    background: rgba(255, 255, 255, 0.15);
  }

  .cloud-1 {
    width: 80px;
    top: 25%;
    left: 15%;
    animation: cloud-drift 20s ease-in-out infinite;
  }

  .cloud-2 {
    width: 60px;
    top: 15%;
    right: 20%;
    animation: cloud-drift 25s ease-in-out infinite reverse;
  }

  .cloud-3 {
    width: 50px;
    top: 35%;
    right: 45%;
    animation: cloud-drift 22s ease-in-out infinite;
  }

  @keyframes cloud-drift {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(20px); }
  }

  .mountain-svg {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .app-overlay {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 12px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    z-index: 3;
  }

  .app-stat {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.75rem;
    display: flex;
    flex-direction: column;
  }

  .app-stat-value {
    color: white;
    font-weight: 700;
    font-size: 1.1rem;
  }

  .app-stat-label {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.7rem;
  }

  .app-status {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-md);
    padding: 0.4rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: white;
    font-size: 0.75rem;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero h1 {
      font-size: 3rem;
    }

    .hero-buttons {
      justify-content: center;
    }

    .hero-image {
      order: -1;
    }
  }

  /* Highlights */
  .highlights {
    background-color: var(--color-bg);
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .highlight-card {
    text-align: center;
    padding: 2rem;
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .highlight-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .highlight-value {
    font-size: 3rem;
    font-weight: 800;
    background: linear-gradient(135deg, #16a34a, #ca8a04);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.25rem;
  }

  .highlight-label {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .highlight-card p {
    color: var(--color-text-light);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .highlights-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Features */
  .features {
    background-color: var(--color-bg-alt);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .feature-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }

  .feature-card p {
    color: var(--color-text-light);
    line-height: 1.7;
    font-size: 0.9rem;
  }

  @media (max-width: 960px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Tech */
  .tech {
    background-color: var(--color-bg);
  }

  .tech-grid {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .tech-card {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem 2rem;
    text-align: center;
    min-width: 200px;
  }

  .tech-card h4 {
    color: #16a34a;
    margin-bottom: 0.5rem;
  }

  .tech-card p {
    color: var(--color-text-light);
    font-size: 0.875rem;
  }

  /* Architecture */
  .architecture {
    background: linear-gradient(180deg, #1a2e1a 0%, #0f1f0f 100%);
    color: white;
  }

  .architecture .section-title h2 {
    color: white;
  }

  .architecture .section-title p {
    color: rgba(255, 255, 255, 0.8);
  }

  .arch-diagram {
    max-width: 800px;
    margin: 0 auto;
  }

  .arch-box {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .arch-box.main {
    padding: 2rem;
  }

  .arch-title {
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: #4ade80;
  }

  .arch-children {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .arch-items {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .arch-items span {
    background: rgba(255, 255, 255, 0.1);
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 768px) {
    .arch-children {
      grid-template-columns: 1fr;
    }
  }

  /* CTA */
  .cta {
    background: linear-gradient(135deg, #16a34a, #ca8a04);
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta h2 {
    color: white;
    margin-bottom: 1rem;
  }

  .cta p {
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
    line-height: 1.8;
  }
</style>
