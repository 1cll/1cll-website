---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const features = [
  {
    icon: '🤖',
    title: 'AIランニングコーチ',
    description: 'Google Gemini AIを搭載。あなたのトレーニングデータを分析し、パーソナライズされたアドバイスを提供します。質問に答え、モチベーションを維持するお手伝いをします。',
  },
  {
    icon: '📸',
    title: 'スクリーンショット自動取り込み',
    description: 'ランニングアプリのスクリーンショットをアップロードするだけで、距離・タイム・ペースなどを自動認識。面倒な手入力は不要です。',
  },
  {
    icon: '📅',
    title: '週間トレーニングプラン',
    description: '目標レースや現在の走力に基づいて、最適な週間トレーニングプランを自動生成。無理なく着実にレベルアップできます。',
  },
  {
    icon: '🎯',
    title: 'ペーシング戦略',
    description: '目標タイムに向けた最適なペース配分を提案。前半抑えめ、後半勝負など、レース展開をシミュレーションできます。',
  },
  {
    icon: '⌚',
    title: 'Garmin/Apple Watch対応',
    description: 'Garmin ConnectやApple Watchのデータと連携。より詳細なトレーニング分析が可能になります。',
  },
  {
    icon: '📊',
    title: '詳細な統計・分析',
    description: '月間・年間の走行距離、平均ペースの推移、目標達成率など、あなたの成長を可視化します。',
  },
];

const useCases = [
  {
    title: 'マラソン完走を目指すランナー',
    description: '初めてのフルマラソン完走に向けて、無理のないトレーニングプランを提案。レース当日までの不安を解消します。',
    icon: '🏃‍♂️',
  },
  {
    title: 'サブ4・サブ3.5を目指す中級ランナー',
    description: '現在のタイムから目標タイムへのギャップを分析し、具体的な改善ポイントとトレーニングメニューを提案します。',
    icon: '🏅',
  },
  {
    title: '記録を管理したいランナー',
    description: 'スクリーンショット一枚で簡単記録。過去の走行履歴を振り返り、成長を実感できます。',
    icon: '📝',
  },
];

const techStack = [
  { name: 'Next.js', description: 'Reactベースのフレームワーク' },
  { name: 'Firebase', description: 'バックエンド・認証・データベース' },
  { name: 'Google Gemini AI', description: 'AIコーチ機能' },
];

const garminFeatures = [
  {
    icon: '🧠',
    title: 'AIによるスマートトレーニング提案',
    description: 'Garminのワークアウト履歴を分析し、毎日3つのトレーニング案（攻め/標準/回復）を提案。過去7日間のトレーニング負荷と睡眠・HRVデータを考慮した科学的な推奨を行います。',
  },
  {
    icon: '📊',
    title: '動的ペースゾーン補正',
    description: 'レース結果に基づく従来のVDOT計算とは異なり、Run Diaryは直近30日間のGarminデータを使用してペースゾーンを継続的に再計算。レースから数ヶ月経っても正確なゾーンを維持します。',
  },
  {
    icon: '🎯',
    title: 'レースペーシング戦略',
    description: 'トレーニングデータから現実的なフィニッシュタイムを予測し、5km毎のスプリット戦略を生成。天気予報（気温・湿度）に応じたペース調整アドバイスも提供します。',
  },
  {
    icon: '💬',
    title: 'コンテキスト認識型AIチャット',
    description: '一般的なAIチャットボットとは異なり、質問内容に応じてGarminデータを動的に参照。週間プラン、疲労度、故障の懸念など—AIが関連データのみを取得してパーソナライズされた回答を提供します。',
  },
];
---

<Layout 
  title="Run Diary - AIコーチ付きランニング日誌" 
  description="Run DiaryはAIコーチ付きランニング日誌アプリ。スクリーンショットからの自動ログ取り込み、週間トレーニングプラン自動生成、目標レースに向けたペーシング戦略でマラソン完走をサポートします。"
>
  <Header currentPath="/products/run-diary" />
  
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content">
            <span class="badge">🏃 ランニングアプリ</span>
            <h1>Run Diary</h1>
            <p class="tagline">AIコーチ付きランニング日誌</p>
            <p class="description">
              マラソン完走を目指すランナーから、サブ4・サブ3を目指す中級ランナーまで。
              Google Gemini AIがあなた専属のランニングコーチとして、
              目標達成までの道のりをサポートします。
            </p>
            <div class="hero-buttons">
              <a href="https://run-diary-2026.web.app" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
                今すぐ使う（無料）
              </a>
              <a href="#features" class="btn btn-secondary">
                機能を見る
              </a>
            </div>
          </div>
          
          <div class="hero-image">
            <div class="phone-mockup large">
              <div class="phone-screen">
                <div class="screen-header">
                  <span class="time">9:41</span>
                </div>
                <div class="app-ui">
                  <div class="app-nav">
                    <span>🏃</span>
                    <span class="app-title">Run Diary</span>
                    <span>⚙️</span>
                  </div>
                  <div class="run-card">
                    <div class="run-date">2026年1月8日（水）</div>
                    <div class="run-stats">
                      <div class="stat">
                        <div class="stat-value">10.5</div>
                        <div class="stat-label">km</div>
                      </div>
                      <div class="stat">
                        <div class="stat-value">52:30</div>
                        <div class="stat-label">時間</div>
                      </div>
                      <div class="stat">
                        <div class="stat-value">5:00</div>
                        <div class="stat-label">/km</div>
                      </div>
                    </div>
                  </div>
                  <div class="weekly-bar">
                    <div class="weekly-label">今週の走行距離</div>
                    <div class="weekly-progress">
                      <div class="weekly-fill"></div>
                    </div>
                    <div class="weekly-text">32.5 / 50 km</div>
                  </div>
                  <div class="ai-chat">
                    <div class="ai-avatar">🤖</div>
                    <div class="ai-message">
                      <p>素晴らしい走りでした！ペース5:00/kmは目標通りです。次回は少しペースを上げて、4:50/kmにチャレンジしてみましょう。</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Features -->
    <section id="features" class="section features">
      <div class="container">
        <div class="section-title">
          <h2>機能</h2>
          <p>Run Diaryがあなたのランニングをサポートする機能</p>
        </div>
        
        <div class="features-grid">
          {features.map(feature => (
            <div class="feature-card">
              <div class="feature-icon">{feature.icon}</div>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Screenshots Gallery -->
    <section class="section screenshots">
      <div class="container">
        <div class="section-title">
          <h2>アプリ画面</h2>
          <p>実際のアプリ画面をご覧ください</p>
        </div>
        
        <div class="screenshots-grid">
          <div class="screenshot-item">
            <div class="screenshot-frame">
              <img src="/images/run-diary/coach.svg" alt="AIコーチ相談画面" loading="lazy" />
            </div>
            <h4>AIコーチに相談</h4>
            <p>過去のログを踏まえて、振り返りや計画の相談ができます</p>
          </div>
          
          <div class="screenshot-item">
            <div class="screenshot-frame">
              <img src="/images/run-diary/history.svg" alt="トレーニング実績画面" loading="lazy" />
            </div>
            <h4>トレーニング実績</h4>
            <p>ワークアウト・リカバリー・バイタルデータを一覧表示</p>
          </div>
          
          <div class="screenshot-item">
            <div class="screenshot-frame">
              <img src="/images/run-diary/plan.svg" alt="トレーニングプラン画面" loading="lazy" />
            </div>
            <h4>トレーニングプラン</h4>
            <p>目標レースに向けた10日間プランを自動生成</p>
          </div>
          
          <div class="screenshot-item">
            <div class="screenshot-frame">
              <img src="/images/run-diary/suggestion.svg" alt="今日の提案画面" loading="lazy" />
            </div>
            <h4>今日の提案</h4>
            <p>コンディションに合わせた最適なトレーニングを提案</p>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Use Cases -->
    <section class="section use-cases">
      <div class="container">
        <div class="section-title">
          <h2>こんな方におすすめ</h2>
          <p>Run Diaryはさまざまなランナーの目標達成をサポートします</p>
        </div>
        
        <div class="use-cases-grid">
          {useCases.map(useCase => (
            <div class="use-case-card">
              <div class="use-case-icon">{useCase.icon}</div>
              <h3>{useCase.title}</h3>
              <p>{useCase.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Garmin Connect Integration -->
    <section id="garmin-integration" class="section garmin-integration">
      <div class="container">
        <div class="section-title">
          <h2>⌚ Garmin Connect連携</h2>
          <p>Garminデータの可能性をAI分析で最大限に引き出す</p>
        </div>
        
        <div class="garmin-intro">
          <p>
            Run DiaryはGarminウェアラブルのデータを実用的なトレーニングインテリジェンスに変換します。
            Garmin Connectは詳細なフィットネス指標の記録に優れていますが、多くのランナーは
            「次に何をすべきか？」という重要な質問に対する答えを見つけるのに苦労しています。
          </p>
          <p>
            Run DiaryはAI分析をGarminデータに適用することでこのギャップを埋め、
            過去のレース結果だけでなく現在のフィットネス状態に適応した
            パーソナライズドコーチングを提供します。
          </p>
        </div>
        
        <div class="garmin-features-grid">
          {garminFeatures.map(feature => (
            <div class="garmin-feature-card">
              <div class="garmin-feature-icon">{feature.icon}</div>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </div>
          ))}
        </div>
        
        <div class="garmin-data-section">
          <h3>Garmin Connectから取得するデータ</h3>
          <p class="data-intro">Run Diaryはパーソナライズドコーチングを提供するために以下のデータタイプを要求します。すべてのデータは安全に処理され、トレーニング体験の向上のためにのみ使用されます。</p>
          
          <div class="data-grid">
            <div class="data-card">
              <div class="data-icon">🏃</div>
              <h4>アクティビティ</h4>
              <p>距離、時間、ペース、心拍数、ケイデンスを含むランニングワークアウトを分析し、トレーニングパターンと進捗を把握します。</p>
            </div>
            <div class="data-card">
              <div class="data-icon">😴</div>
              <h4>睡眠データ</h4>
              <p>睡眠時間と品質指標を考慮し、回復状況をトレーニング推奨に反映します。</p>
            </div>
            <div class="data-card">
              <div class="data-icon">❤️</div>
              <h4>心拍変動（HRV）</h4>
              <p>HRV測定値から生理学的レディネスを評価し、オーバートレーニングを防止します。</p>
            </div>
            <div class="data-card">
              <div class="data-icon">📈</div>
              <h4>VO2 Max推定値</h4>
              <p>フィットネスレベル推定値を使用してペースゾーンとレース予測を動的に調整します。</p>
            </div>
            <div class="data-card">
              <div class="data-icon">⚡</div>
              <h4>トレーニング負荷</h4>
              <p>累積トレーニングストレスを把握し、ワークアウト強度と回復期間のバランスを取ります。</p>
            </div>
            <div class="data-card">
              <div class="data-icon">🔋</div>
              <h4>Body Battery / レディネス</h4>
              <p>日々のエネルギーレベルに基づいて適切なトレーニング強度を推奨します。</p>
            </div>
          </div>
        </div>
        
        <div class="comparison-section">
          <h3>Run DiaryとGarmin Connectの相互補完</h3>
          <div class="comparison-table-wrapper">
            <table class="comparison-table">
              <thead>
                <tr>
                  <th>機能</th>
                  <th>Garmin Connect</th>
                  <th>Strava</th>
                  <th>TrainingPeaks</th>
                  <th>Run Diary</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>データ記録</td>
                  <td>✅</td>
                  <td>✅</td>
                  <td>✅</td>
                  <td>✅（Garmin経由）</td>
                </tr>
                <tr>
                  <td>AIトレーニング提案</td>
                  <td>❌</td>
                  <td>❌</td>
                  <td>❌</td>
                  <td>✅ 毎日3案</td>
                </tr>
                <tr>
                  <td>動的ペースゾーン</td>
                  <td>❌</td>
                  <td>❌</td>
                  <td>❌</td>
                  <td>✅ 直近30日反映</td>
                </tr>
                <tr>
                  <td>AIチャットコーチ</td>
                  <td>❌</td>
                  <td>❌</td>
                  <td>❌</td>
                  <td>✅ 10種類のコーチ性格</td>
                </tr>
                <tr>
                  <td>多言語AI対応</td>
                  <td>❌</td>
                  <td>❌</td>
                  <td>❌</td>
                  <td>✅ 日本語/英語</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        
        <div class="user-story">
          <blockquote>
            「Garminで毎日記録しているけど、データを見て『次何しよう？』と悩む日々でした。
            Run Diaryを使い始めてからは、朝起きたら今日のおすすめトレーニングがAIから届く。
            睡眠が悪かった日は自動で回復メニューが提案される。
            もうトレーニング計画に悩むことはなくなりました。」
          </blockquote>
          <cite>— Run Diaryユーザー</cite>
        </div>
        
        <div class="garmin-benefits">
          <h3>Garminエコシステムへのメリット</h3>
          <div class="benefits-grid">
            <div class="benefit-card">
              <div class="benefit-icon">🔗</div>
              <h4>デバイス価値の向上</h4>
              <p>Run Diaryが生データを実用的なインサイトに変換することで、Garminデバイスの価値がさらに高まります。</p>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">📊</div>
              <h4>データ活用の促進</h4>
              <p>収集されたデータがAI分析を通じて実践的なアドバイスに変換されます。</p>
            </div>
            <div class="benefit-card">
              <div class="benefit-icon">🎯</div>
              <h4>ユーザーエンゲージメント</h4>
              <p>毎日のAI提案により、Garminデバイスの使用継続率と定着率が向上します。</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- How It Works -->
    <section class="section how-it-works">
      <div class="container">
        <div class="section-title">
          <h2>使い方</h2>
          <p>3ステップで簡単スタート</p>
        </div>
        
        <div class="steps">
          <div class="step">
            <div class="step-number">1</div>
            <h3>アカウント作成</h3>
            <p>Googleアカウントで簡単登録。すぐに使い始められます。</p>
          </div>
          
          <div class="step-arrow">→</div>
          
          <div class="step">
            <div class="step-number">2</div>
            <h3>走行記録を追加</h3>
            <p>スクリーンショットをアップロード、または手動で入力。AIが自動でデータを読み取ります。</p>
          </div>
          
          <div class="step-arrow">→</div>
          
          <div class="step">
            <div class="step-number">3</div>
            <h3>AIコーチに相談</h3>
            <p>トレーニングの悩み、ペース配分、食事など何でも相談。パーソナライズされたアドバイスが得られます。</p>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Tech Stack -->
    <section class="section tech">
      <div class="container">
        <div class="section-title">
          <h2>技術スタック</h2>
          <p>最新のテクノロジーで構築</p>
        </div>
        
        <div class="tech-grid">
          {techStack.map(tech => (
            <div class="tech-card">
              <h4>{tech.name}</h4>
              <p>{tech.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <!-- CTA -->
    <section class="section cta">
      <div class="container">
        <div class="cta-content">
          <h2>今すぐRun Diaryを始めよう</h2>
          <p>無料でアカウントを作成し、AIコーチと一緒にトレーニングを始めましょう。</p>
          <a href="https://run-diary-2026.web.app" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
            無料で始める →
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 4rem 0 6rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
  }
  
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: var(--color-primary);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
  }
  
  .hero h1 {
    font-size: 4rem;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .tagline {
    font-size: 1.5rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }
  
  .description {
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  
  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  /* Phone Mockup */
  .hero-image {
    display: flex;
    justify-content: center;
  }
  
  .phone-mockup.large {
    width: 320px;
    height: 640px;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    border-radius: 44px;
    padding: 12px;
    box-shadow: var(--shadow-xl);
  }
  
  .phone-screen {
    width: 100%;
    height: 100%;
    background: #0f172a;
    border-radius: 32px;
    overflow: hidden;
  }
  
  .screen-header {
    padding: 0.75rem 1.5rem;
    text-align: center;
  }
  
  .time {
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
  }
  
  .app-ui {
    padding: 0 1rem 1rem;
  }
  
  .app-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    color: white;
  }
  
  .app-title {
    font-weight: 600;
    font-size: 1.1rem;
  }
  
  .run-card {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1rem;
  }
  
  .run-date {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  
  .run-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    text-align: center;
  }
  
  .stat-value {
    font-size: 1.5rem;
