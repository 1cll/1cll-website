---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const features = [
  {
    icon: '🔄',
    title: 'マルチリポジトリ監視',
    description: '単一プロセスで複数のGitHubリポジトリを監視。Issue検知からAI実行までを一元管理します。',
  },
  {
    icon: '🤖',
    title: 'マルチAIエージェント',
    description: 'GitHub Copilot CLI、Claude Code、OpenAI Codexをプラガブルに切替・フォールバック。最適なAIを自動選択します。',
  },
  {
    icon: '📅',
    title: 'スケジュール実行',
    description: 'cron式で依存更新、lint修正、セキュリティスキャンなどの定期タスクを自動実行します。',
  },
  {
    icon: '🔒',
    title: 'Active-Standby冗長構成',
    description: 'Fencing Token付きリーダー選出でスプリットブレインを防止。高可用性を実現します。',
  },
  {
    icon: '🔍',
    title: 'SRE Agent',
    description: 'GCP/AWS/Azureのログ監視から異常検知、Issue自動作成、AI自動修復までを統合管理します。',
  },
  {
    icon: '⚡',
    title: 'Pipeline Watcher',
    description: 'GitHub Actions失敗を検知し、修復Issueを自動作成。CI/CDパイプラインの安定性を維持します。',
  },
];

const components = [
  {
    name: 'Worker',
    description: 'Issue監視、AIエージェント実行、CI/CDパイプライン監視を担当するバックグラウンドプロセス',
    icon: '⚙️',
  },
  {
    name: 'API',
    description: 'ダッシュボードや外部システムとの連携を提供するREST APIサーバー',
    icon: '🔌',
  },
  {
    name: 'Dashboard',
    description: 'リポジトリ状態、Issue処理状況、AI実行ログを可視化するWeb UI',
    icon: '📊',
  },
];

const techStack = [
  { name: 'Go', description: 'バックエンド（シングルバイナリ）' },
  { name: 'React + TypeScript', description: 'ダッシュボードUI' },
  { name: 'Google Cloud Run', description: 'インフラストラクチャ' },
  { name: 'Firebase / Firestore', description: 'ホスティング・データベース' },
];

const vcsProviders = [
  { name: 'GitHub', description: 'Issue/PR/Actions 完全対応', auth: 'PAT / OAuth / GitHub App' },
  { name: 'GitLab', description: 'Issue/MR/Pipeline 対応', auth: 'Personal Access Token' },
  { name: 'Bitbucket', description: 'Issue/PR/Pipeline 対応', auth: 'App Password / OAuth' },
];
---

<Layout
  title="ADOS - AI DevOps as a Service"
  description="ADOS（AI-powered Development Operations System）は、GitHub IssueをAIエージェントで自動処理し、Pull Requestを作成するまでのワークフローをオーケストレーションする開発運用プラットフォームです。"
>
  <Header currentPath="/products/ados" />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content">
            <span class="badge">⚡ AI DevOps プラットフォーム</span>
            <h1>ADOS</h1>
            <p class="tagline">AI DevOps as a Service</p>
            <p class="description">
              GitHub IssueをAIコーディングエージェントが自動処理し、Pull Requestを作成するまでの
              一連のワークフローをオーケストレーション。複数リポジトリの監視からAI実行までを統合管理する
              開発運用プラットフォームです。
            </p>
            <div class="hero-buttons">
              <a href="https://ados.dev" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
                ados.dev を見る
              </a>
              <a href="https://docs.ados.dev" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
                ドキュメント
              </a>
            </div>
          </div>

          <div class="hero-image">
            <div class="terminal-mockup">
              <div class="terminal-header">
                <div class="terminal-dots">
                  <span class="dot red"></span>
                  <span class="dot yellow"></span>
                  <span class="dot green"></span>
                </div>
                <span class="terminal-title">ados</span>
              </div>
              <div class="terminal-body">
                <div class="terminal-line">
                  <span class="prompt">$</span>
                  <span class="command">ados start --config ados.yaml</span>
                </div>
                <div class="terminal-line output">
                  <span class="log-time">09:00:01</span>
                  <span class="log-info">INFO</span>
                  <span>Leader elected (node-1, token: 7f3d)</span>
                </div>
                <div class="terminal-line output">
                  <span class="log-time">09:00:01</span>
                  <span class="log-info">INFO</span>
                  <span>Watching 5 repositories...</span>
                </div>
                <div class="terminal-line output">
                  <span class="log-time">09:00:15</span>
                  <span class="log-info">INFO</span>
                  <span>Issue #42 detected in myapp</span>
                </div>
                <div class="terminal-line output">
                  <span class="log-time">09:00:16</span>
                  <span class="log-agent">AGENT</span>
                  <span>Claude Code processing #42...</span>
                </div>
                <div class="terminal-line output">
                  <span class="log-time">09:02:33</span>
                  <span class="log-agent">AGENT</span>
                  <span>Running test suite (47 tests)...</span>
                </div>
                <div class="terminal-line output">
                  <span class="log-time">09:03:10</span>
                  <span class="log-success">PASS</span>
                  <span>All 47 tests passed</span>
                </div>
                <div class="terminal-line output">
                  <span class="log-time">09:03:42</span>
                  <span class="log-success">OK</span>
                  <span>PR #43 created successfully</span>
                </div>
                <div class="terminal-line output">
                  <span class="log-time">09:05:01</span>
                  <span class="log-info">INFO</span>
                  <span>Scheduled task: dep-update (api-srv)</span>
                </div>
                <div class="terminal-line output">
                  <span class="log-time">09:05:02</span>
                  <span class="log-agent">AGENT</span>
                  <span>Copilot processing dep-update...</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Flow -->
    <section class="section flow">
      <div class="container">
        <div class="section-title">
          <h2>ワークフロー</h2>
          <p>Issue から Pull Request までを完全自動化</p>
        </div>

        <div class="flow-diagram">
          <div class="flow-step">
            <div class="flow-icon">📝</div>
            <div class="flow-label">GitHub Issue</div>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step">
            <div class="flow-icon">🔍</div>
            <div class="flow-label">ADOS 検知</div>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step">
            <div class="flow-icon">🤖</div>
            <div class="flow-label">AI Agent 実行</div>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step">
            <div class="flow-icon">🔀</div>
            <div class="flow-label">Pull Request</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Components -->
    <section class="section components">
      <div class="container">
        <div class="section-title">
          <h2>主要コンポーネント</h2>
          <p>ADOSを構成する3つの主要コンポーネント</p>
        </div>

        <div class="components-grid">
          {components.map(comp => (
            <div class="component-card">
              <div class="component-icon">{comp.icon}</div>
              <h3>{comp.name}</h3>
              <p>{comp.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="section features">
      <div class="container">
        <div class="section-title">
          <h2>機能</h2>
          <p>開発運用を効率化する主要機能</p>
        </div>

        <div class="features-grid">
          {features.map(feature => (
            <div class="feature-card">
              <div class="feature-icon">{feature.icon}</div>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- VCS Providers -->
    <section class="section vcs-section">
      <div class="container">
        <div class="section-title">
          <h2>マルチVCS対応</h2>
          <p>GitHub に加えて GitLab・Bitbucket もサポート</p>
        </div>

        <div class="vcs-grid">
          {vcsProviders.map(provider => (
            <div class="vcs-card">
              <h3>{provider.name}</h3>
              <p class="vcs-desc">{provider.description}</p>
              <p class="vcs-auth">認証: {provider.auth}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="section tech">
      <div class="container">
        <div class="section-title">
          <h2>技術スタック</h2>
          <p>堅牢なインフラストラクチャ</p>
        </div>

        <div class="tech-grid">
          {techStack.map(tech => (
            <div class="tech-card">
              <h4>{tech.name}</h4>
              <p>{tech.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="section architecture">
      <div class="container">
        <div class="section-title">
          <h2>アーキテクチャ</h2>
          <p>Goシングルバイナリによるシンプルかつ堅牢な構成</p>
        </div>

        <div class="arch-diagram">
          <div class="arch-box main">
            <div class="arch-title">ados (シングルバイナリ)</div>
            <div class="arch-children">
              <div class="arch-box">
                <div class="arch-title">Orchestrator</div>
                <div class="arch-items">
                  <span>Leader Election</span>
                  <span>Agent Scheduler</span>
                  <span>Worker Pool</span>
                </div>
              </div>
              <div class="arch-box">
                <div class="arch-title">Agent Layer</div>
                <div class="arch-items">
                  <span>Copilot</span>
                  <span>Claude Code</span>
                  <span>Codex</span>
                </div>
              </div>
              <div class="arch-box">
                <div class="arch-title">State Store</div>
                <div class="arch-items">
                  <span>SQLite</span>
                  <span>Firestore</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section cta">
      <div class="container">
        <div class="cta-content">
          <h2>ADOSで開発運用を自動化しよう</h2>
          <p>
            GitHub IssueからPull Requestまで、AIが自動で対応。
            開発チームはより創造的な仕事に集中できます。
          </p>
          <div class="cta-buttons">
            <a href="https://ados.dev" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              ados.dev にアクセス
            </a>
            <a href="https://docs.ados.dev" class="btn btn-secondary-light" target="_blank" rel="noopener noreferrer">
              ドキュメントを読む
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 4rem 0 6rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: var(--color-primary);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: 4rem;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, var(--color-primary), #8B5CF6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .tagline {
    font-size: 1.5rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  .description {
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Terminal Mockup */
  .hero-image {
    display: flex;
    justify-content: center;
  }

  .terminal-mockup {
    width: 100%;
    max-width: 520px;
    background: #1e1e2e;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl), 0 0 60px rgba(139, 92, 246, 0.15);
    overflow: hidden;
    border: 1px solid rgba(139, 92, 246, 0.25);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: #181825;
  }

  .terminal-dots {
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background: #f38ba8; }
  .dot.yellow { background: #f9e2af; }
  .dot.green { background: #a6e3a1; }

  .terminal-title {
    color: #cdd6f4;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .terminal-body {
    padding: 1.25rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.8rem;
    line-height: 1.8;
  }

  .terminal-line {
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .prompt {
    color: #a6e3a1;
    font-weight: 700;
  }

  .command {
    color: #cdd6f4;
  }

  .terminal-line.output {
    color: #bac2de;
  }

  .log-time {
    color: #6c7086;
  }

  .log-info {
    color: #89b4fa;
    font-weight: 600;
  }

  .log-agent {
    color: #cba6f7;
    font-weight: 600;
  }

  .log-success {
    color: #a6e3a1;
    font-weight: 600;
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero h1 {
      font-size: 3rem;
    }

    .hero-buttons {
      justify-content: center;
    }

    .hero-image {
      order: -1;
    }
  }

  /* Flow */
  .flow {
    background-color: var(--color-bg);
  }

  .flow-diagram {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .flow-step {
    text-align: center;
    padding: 1.5rem 2rem;
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    min-width: 140px;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .flow-step:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .flow-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .flow-label {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .flow-arrow {
    font-size: 1.5rem;
    color: var(--color-primary);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .flow-diagram {
      flex-direction: column;
    }

    .flow-arrow {
      transform: rotate(90deg);
    }
  }

  /* Components */
  .components {
    background-color: var(--color-bg-alt);
  }

  .components-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .component-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .component-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .component-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .component-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    color: var(--color-primary);
  }

  .component-card p {
    color: var(--color-text-light);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .components-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Features */
  .features {
    background-color: var(--color-bg);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .feature-card {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  .feature-card p {
    color: var(--color-text-light);
    line-height: 1.7;
  }

  @media (max-width: 960px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  /* VCS Providers */
  .vcs-section {
    background-color: var(--color-bg-alt);
  }

  .vcs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .vcs-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    text-align: center;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .vcs-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .vcs-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }

  .vcs-desc {
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
    line-height: 1.7;
  }

  .vcs-auth {
    font-size: 0.8rem;
    color: var(--color-text-lighter);
  }

  @media (max-width: 768px) {
    .vcs-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Tech */
  .tech {
    background-color: var(--color-bg);
  }

  .tech-grid {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .tech-card {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem 2rem;
    text-align: center;
    min-width: 200px;
  }

  .tech-card h4 {
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .tech-card p {
    color: var(--color-text-light);
    font-size: 0.875rem;
  }

  /* Architecture */
  .architecture {
    background: linear-gradient(180deg, #1a1f2e 0%, #0f1419 100%);
    color: white;
  }

  .architecture .section-title h2 {
    color: white;
  }

  .architecture .section-title p {
    color: rgba(255, 255, 255, 0.8);
  }

  .arch-diagram {
    max-width: 800px;
    margin: 0 auto;
  }

  .arch-box {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .arch-box.main {
    padding: 2rem;
  }

  .arch-title {
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: #60a5fa;
  }

  .arch-children {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .arch-items {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .arch-items span {
    background: rgba(255, 255, 255, 0.1);
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 768px) {
    .arch-children {
      grid-template-columns: 1fr;
    }
  }

  /* CTA */
  .cta {
    background: linear-gradient(135deg, var(--color-primary), #8B5CF6);
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta h2 {
    color: white;
    margin-bottom: 1rem;
  }

  .cta p {
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta .btn-primary {
    background-color: white;
    color: var(--color-primary);
  }

  .cta .btn-primary:hover {
    background-color: rgba(255, 255, 255, 0.9);
  }

  .btn-secondary-light {
    background-color: transparent;
    color: white;
    border: 2px solid white;
  }

  .btn-secondary-light:hover {
    background-color: rgba(255, 255, 255, 0.1);
    color: white;
  }
</style>
