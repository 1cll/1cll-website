---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const features = [
  {
    icon: '🤖',
    title: 'AIコーチ',
    description: 'パーソナライズされたアドバイスで目標達成をサポート',
  },
  {
    icon: '📸',
    title: '自動ログ取り込み',
    description: 'スクリーンショットから走行データを自動認識',
  },
  {
    icon: '📅',
    title: 'トレーニングプラン',
    description: '週間プランを自動生成し、効率的な練習をサポート',
  },
  {
    icon: '🎯',
    title: 'ペーシング戦略',
    description: '目標レースに向けた最適なペース配分を提案',
  },
];
---

<Layout 
  title="ホーム" 
  description="Creative Life Labo - ライフスタイル向上のためのアプリ・サービス開発。AIコーチ付きランニング日誌アプリ「Run Diary」を提供しています。"
>
  <Header currentPath="/" />
  
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <h1 class="hero-title">
            テクノロジーで、<br />
            <span class="gradient-text">ライフスタイルを向上</span>
          </h1>
          <p class="hero-description">
            Creative Life Laboは、日々の生活をより豊かにするアプリ・サービスを開発しています。
            AIを活用したスマートなソリューションで、あなたの目標達成をサポートします。
          </p>
          <div class="hero-buttons">
            <a href="#products" class="btn btn-primary">
              プロダクトを見る
            </a>
            <a href="/about" class="btn btn-secondary">
              会社について
            </a>
          </div>
        </div>
      </div>
      <div class="hero-bg"></div>
    </section>
    
    <!-- Products Section -->
    <section id="products" class="section products">
      <div class="container">
        <div class="section-title">
          <h2>プロダクト</h2>
          <p>私たちが開発したアプリ・サービス</p>
        </div>

        <div class="product-card ados-card">
          <div class="product-content">
            <span class="product-badge ados-badge">AI DevOps プラットフォーム</span>
            <h3 class="product-title">ADOS</h3>
            <p class="product-subtitle">AI DevOps as a Service</p>
            <p class="product-description">
              GitHub IssueをAIコーディングエージェントが自動処理し、Pull Requestを作成するまでの
              ワークフローをオーケストレーション。複数リポジトリの監視からAI実行までを統合管理する
              開発運用プラットフォームです。
            </p>

            <div class="product-features">
              <div class="feature-item">
                <span class="feature-icon">🔄</span>
                <div>
                  <h4>マルチリポジトリ</h4>
                  <p>複数リポを単一プロセスで監視</p>
                </div>
              </div>
              <div class="feature-item">
                <span class="feature-icon">🤖</span>
                <div>
                  <h4>マルチAIエージェント</h4>
                  <p>Copilot / Claude / Codex を自動切替</p>
                </div>
              </div>
              <div class="feature-item">
                <span class="feature-icon">📅</span>
                <div>
                  <h4>スケジュール実行</h4>
                  <p>cron式で定期タスクを自動実行</p>
                </div>
              </div>
              <div class="feature-item">
                <span class="feature-icon">🔍</span>
                <div>
                  <h4>SRE Agent</h4>
                  <p>クラウドログ監視・自動修復</p>
                </div>
              </div>
            </div>

            <div class="product-buttons">
              <a href="/products/ados" class="btn btn-primary">
                詳細を見る
              </a>
              <a href="https://ados.dev" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
                ados.dev →
              </a>
            </div>
          </div>

          <div class="product-image">
            <div class="terminal-preview">
              <div class="terminal-preview-header">
                <div class="terminal-preview-dots">
                  <span class="tdot red"></span>
                  <span class="tdot yellow"></span>
                  <span class="tdot green"></span>
                </div>
                <span class="terminal-preview-title">ados</span>
              </div>
              <div class="terminal-preview-body">
                <div class="tline"><span class="tprompt">$</span> ados start --config ados.yaml</div>
                <div class="tline"><span class="ttime">09:00:01</span> <span class="tinfo">INFO</span> Watching 5 repositories...</div>
                <div class="tline"><span class="ttime">09:00:15</span> <span class="tinfo">INFO</span> Issue #42 detected in myapp</div>
                <div class="tline"><span class="ttime">09:00:16</span> <span class="tagent">AGENT</span> Claude Code processing...</div>
                <div class="tline"><span class="ttime">09:02:33</span> <span class="tagent">AGENT</span> Running tests...</div>
                <div class="tline"><span class="ttime">09:03:10</span> <span class="tinfo">INFO</span> All 47 tests passed</div>
                <div class="tline"><span class="ttime">09:03:42</span> <span class="tok">OK</span> PR #43 created successfully</div>
                <div class="tline"><span class="ttime">09:05:01</span> <span class="tinfo">INFO</span> Issue #44 detected in api-srv</div>
                <div class="tline"><span class="ttime">09:05:02</span> <span class="tagent">AGENT</span> Copilot processing...</div>
              </div>
            </div>
          </div>
        </div>

        <div class="product-spacer"></div>

        <div class="product-card">
          <div class="product-content">
            <span class="product-badge">ランニングアプリ</span>
            <h3 class="product-title">Run Diary</h3>
            <p class="product-subtitle">AIコーチ付きランニング日誌</p>
            <p class="product-description">
              Google Gemini AIを搭載したランニング日誌アプリ。
              スクリーンショットからの自動ログ取り込み、週間トレーニングプラン自動生成、
              目標レースに向けたペーシング戦略など、マラソン完走を目指すランナーから
              サブ4〜サブ3を目指す中級ランナーまで幅広くサポートします。
            </p>
            
            <div class="product-features">
              {features.map(feature => (
                <div class="feature-item">
                  <span class="feature-icon">{feature.icon}</span>
                  <div>
                    <h4>{feature.title}</h4>
                    <p>{feature.description}</p>
                  </div>
                </div>
              ))}
            </div>
            
            <div class="product-buttons">
              <a href="/products/run-diary" class="btn btn-primary">
                詳細を見る
              </a>
              <a href="https://run-diary-2026.web.app" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
                アプリを使う →
              </a>
            </div>
          </div>
          
          <div class="product-image">
            <div class="phone-mockup">
              <div class="phone-screen">
                <div class="screen-header">
                  <span class="time">9:41</span>
                </div>
                <div class="app-ui">
                  <div class="app-nav">
                    <span>🏃</span>
                    <span class="app-title">Run Diary</span>
                    <span>⚙️</span>
                  </div>
                  <div class="run-card">
                    <div class="run-date">2026年1月8日（水）</div>
                    <div class="run-stats">
                      <div class="stat">
                        <div class="stat-value">10.5</div>
                        <div class="stat-label">km</div>
                      </div>
                      <div class="stat">
                        <div class="stat-value">52:30</div>
                        <div class="stat-label">時間</div>
                      </div>
                      <div class="stat">
                        <div class="stat-value">5:00</div>
                        <div class="stat-label">/km</div>
                      </div>
                    </div>
                  </div>
                  <div class="weekly-bar">
                    <div class="weekly-label">今週の走行距離</div>
                    <div class="weekly-progress">
                      <div class="weekly-fill"></div>
                    </div>
                    <div class="weekly-text">32.5 / 50 km</div>
                  </div>
                  <div class="chat-bubble">
                    <span>🤖</span>
                    <p>今週の走行距離は順調です！次のレースに向けて、少しペースを上げていきましょう。</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="product-spacer"></div>

        <div class="product-card yamago-card">
          <div class="product-content">
            <span class="product-badge yamago-badge">総合登山プラットフォーム</span>
            <h3 class="product-title">YAMAGO</h3>
            <p class="product-subtitle">山へ行く人のためのアプリ</p>
            <p class="product-description">
              ルート計画からGPS追跡、緊急SOS、山岳気象、フィットネス管理、AI分析まで、
              登山のすべてをカバーする総合プラットフォーム。130以上のモジュールと
              333のテストで構築された信頼性の高いPWAアプリです。
            </p>

            <div class="product-features">
              <div class="feature-item">
                <span class="feature-icon">🗺️</span>
                <div>
                  <h4>AIルート計画</h4>
                  <p>体力に合わせた最適ルート提案</p>
                </div>
              </div>
              <div class="feature-item">
                <span class="feature-icon">🆘</span>
                <div>
                  <h4>安全 & 緊急対応</h4>
                  <p>ワンタップSOS・危険区域アラート</p>
                </div>
              </div>
              <div class="feature-item">
                <span class="feature-icon">🌤️</span>
                <div>
                  <h4>山岳気象</h4>
                  <p>山特化の天気予報・装備推奨</p>
                </div>
              </div>
              <div class="feature-item">
                <span class="feature-icon">🧠</span>
                <div>
                  <h4>AI/MLエンジン</h4>
                  <p>疲労予測・リスク評価・チャットボット</p>
                </div>
              </div>
            </div>

            <div class="product-buttons">
              <a href="/products/yamago" class="btn btn-primary yamago-btn">
                詳細を見る
              </a>
            </div>
          </div>

          <div class="product-image">
            <div class="mountain-preview">
              <div class="mountain-preview-scene">
                <div class="mp-sky">
                  <div class="mp-cloud mp-cloud-1"></div>
                  <div class="mp-cloud mp-cloud-2"></div>
                  <div class="mp-cloud mp-cloud-3"></div>
                </div>
                <svg class="mp-scene-svg" viewBox="0 0 360 220" preserveAspectRatio="xMidYMax slice">
                  <!-- Back mountain -->
                  <path d="M -20 220 L 60 70 Q 75 50 90 65 L 120 95 Q 130 80 140 85 L 200 220 Z" fill="#6b8e73"/>
                  <path d="M 60 70 Q 75 50 90 65 L 85 75 Q 75 60 68 72 Z" fill="white" opacity="0.7"/>
                  <!-- Mid mountain (tallest) -->
                  <path d="M 80 220 L 170 35 Q 185 15 200 30 L 220 55 Q 230 45 240 50 L 300 220 Z" fill="#4a7c59"/>
                  <path d="M 170 35 Q 185 15 200 30 L 195 42 Q 185 25 175 38 Z" fill="white" opacity="0.8"/>
                  <path d="M 220 55 Q 225 48 230 50 L 228 56 Z" fill="white" opacity="0.5"/>
                  <!-- Front mountain -->
                  <path d="M 200 220 L 280 75 Q 295 55 310 70 L 330 95 Q 340 88 350 92 L 380 220 Z" fill="#3d6b4e"/>
                  <path d="M 280 75 Q 295 55 310 70 L 305 80 Q 295 62 285 78 Z" fill="white" opacity="0.7"/>
                  <!-- Tree silhouettes -->
                  <path d="M 20 210 L 25 190 L 22 192 L 27 178 L 24 180 L 28 170 L 32 180 L 29 178 L 34 192 L 31 190 L 35 210 Z" fill="#2d5a3a" opacity="0.7"/>
                  <path d="M 45 215 L 49 198 L 47 200 L 51 188 L 49 190 L 52 182 L 55 190 L 53 188 L 57 200 L 55 198 L 58 215 Z" fill="#2d5a3a" opacity="0.6"/>
                  <path d="M 320 215 L 324 200 L 322 202 L 326 192 L 324 194 L 327 186 L 330 194 L 328 192 L 332 202 L 330 200 L 334 215 Z" fill="#1e4a2e" opacity="0.7"/>
                  <path d="M 340 218 L 343 205 L 341 207 L 345 198 L 348 207 L 346 205 L 349 218 Z" fill="#1e4a2e" opacity="0.5"/>
                  <!-- Trail -->
                  <path d="M 15 205 Q 50 180 80 155 Q 110 130 140 110 Q 170 90 195 70 Q 215 55 240 35" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-dasharray="6 3" stroke-linecap="round"/>
                  <circle cx="15" cy="205" r="4" fill="#22c55e"/>
                  <circle cx="140" cy="110" r="3.5" fill="#f59e0b"/>
                  <circle cx="240" cy="35" r="4" fill="#ef4444"/>
                </svg>
                <div class="mp-overlay">
                  <div class="mp-stat">
                    <span class="mp-stat-val">2,847m</span>
                  </div>
                  <div class="mp-gps">
                    <span class="mp-gps-dot"></span>
                    GPS
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Company Section -->
    <section class="section company">
      <div class="container">
        <div class="section-title">
          <h2>会社概要</h2>
          <p>Creative Life Laboについて</p>
        </div>
        
        <div class="company-content">
          <div class="company-card">
            <div class="company-icon">🎯</div>
            <h3>ミッション</h3>
            <p>テクノロジーの力で、人々の日常生活をより豊かに、より効率的にすること</p>
          </div>
          
          <div class="company-card">
            <div class="company-icon">🌟</div>
            <h3>ビジョン</h3>
            <p>誰もが自分らしいライフスタイルを実現できる世界を創る</p>
          </div>
          
          <div class="company-card">
            <div class="company-icon">💡</div>
            <h3>アプローチ</h3>
            <p>最新のAI技術を活用し、パーソナライズされた体験を提供する</p>
          </div>
        </div>
        
        <div class="company-cta">
          <a href="/about" class="btn btn-secondary">
            詳しく見る →
          </a>
        </div>
      </div>
    </section>
    
    <!-- Client Work Section -->
    <section class="section client-work">
      <div class="container">
        <div class="section-title">
          <h2>業務委託実績</h2>
          <p>これまでに手がけたクライアントプロジェクト</p>
        </div>

        <div class="client-grid">
          <div class="client-card">
            <div class="client-icon">🪪</div>
            <h3>JAC会員カードアプリ</h3>
            <p class="client-org">日本山岳会向け</p>
            <p class="client-desc">会員証デジタル化、QRコード認証、会員特典検索機能を備えたWebアプリケーション。</p>
            <div class="client-tech">
              <span>Next.js</span>
              <span>Firebase</span>
              <span>Tailwind CSS</span>
            </div>
          </div>

          <div class="client-card">
            <div class="client-icon">👥</div>
            <h3>JACユースクラブ管理</h3>
            <p class="client-org">日本山岳会ユースクラブ向け</p>
            <p class="client-desc">入会申請承認ワークフロー、Google Group連携による会員管理システム。</p>
            <div class="client-tech">
              <span>Next.js</span>
              <span>Firebase</span>
              <span>Google API</span>
            </div>
          </div>

          <div class="client-card">
            <div class="client-icon">📋</div>
            <h3>確定申告データ管理</h3>
            <p class="client-org">個人事業主向け</p>
            <p class="client-desc">確定申告のデータ整理・経費集計を自動化。GitHub Issue連携のタスク管理。</p>
            <div class="client-tech">
              <span>GitHub API</span>
              <span>Automation</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section cta">
      <div class="container">
        <div class="cta-content">
          <h2>お問い合わせ</h2>
          <p>
            プロダクトに関するご質問、パートナーシップのご相談など、
            お気軽にお問い合わせください。
          </p>
          <a href="/contact" class="btn btn-primary">
            お問い合わせはこちら
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: 6rem 0;
    overflow: hidden;
  }
  
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }
  
  .hero-title {
    font-size: 3.5rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  
  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .hero-description {
    font-size: 1.25rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
    line-height: 1.8;
  }
  
  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .hero-bg {
    position: absolute;
    top: -50%;
    right: -20%;
    width: 70%;
    height: 200%;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
    z-index: 0;
  }
  
  @media (max-width: 768px) {
    .hero {
      padding: 4rem 0;
    }
    
    .hero-title {
      font-size: 2.5rem;
    }
    
    .hero-description {
      font-size: 1.1rem;
    }
  }
  
  /* Products */
  .products {
    background-color: var(--color-bg-alt);
  }
  
  .product-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .product-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background-color: var(--color-primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: var(--radius-sm);
    margin-bottom: 1rem;
  }
  
  .product-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  
  .product-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }
  
  .product-description {
    color: var(--color-text-light);
    margin-bottom: 2rem;
    line-height: 1.8;
  }
  
  .product-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  
  .feature-item {
    display: flex;
    gap: 1rem;
  }
  
  .feature-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }
  
  .feature-item h4 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  
  .feature-item p {
    font-size: 0.875rem;
    color: var(--color-text-light);
  }
  
  .product-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  /* Product Spacer */
  .product-spacer {
    height: 4rem;
  }

  /* ADOS Badge */
  .ados-badge {
    background: linear-gradient(135deg, var(--color-primary), #8B5CF6);
  }

  /* Terminal Preview (ADOS) */
  .terminal-preview {
    width: 100%;
    max-width: 420px;
    background: #1e1e2e;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl), 0 0 40px rgba(139, 92, 246, 0.15);
    overflow: hidden;
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .terminal-preview-header {
    padding: 0.6rem 0.75rem;
    background: #181825;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .terminal-preview-dots {
    display: flex;
    gap: 0.4rem;
  }

  .terminal-preview-title {
    color: #6c7086;
    font-size: 0.7rem;
    font-weight: 500;
  }

  .tdot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .tdot.red { background: #f38ba8; }
  .tdot.yellow { background: #f9e2af; }
  .tdot.green { background: #a6e3a1; }

  .terminal-preview-body {
    padding: 1rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.72rem;
    line-height: 1.8;
  }

  .tline {
    color: #bac2de;
  }

  .tprompt {
    color: #a6e3a1;
    font-weight: 700;
  }

  .ttime {
    color: #6c7086;
  }

  .tinfo {
    color: #89b4fa;
    font-weight: 600;
  }

  .tagent {
    color: #cba6f7;
    font-weight: 600;
  }

  .tok {
    color: #a6e3a1;
    font-weight: 600;
  }

  /* Phone Mockup */
  .product-image {
    display: flex;
    justify-content: center;
  }

  .phone-mockup {
    width: 280px;
    height: 560px;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    border-radius: 40px;
    padding: 12px;
    box-shadow: var(--shadow-xl);
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    background: #0f172a;
    border-radius: 28px;
    overflow: hidden;
  }

  .screen-header {
    padding: 0.5rem 1rem;
    text-align: center;
  }

  .time {
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .app-ui {
    padding: 0 0.75rem 0.75rem;
  }

  .app-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    color: white;
  }

  .app-title {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .run-card {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    border-radius: var(--radius-lg);
    padding: 0.75rem;
