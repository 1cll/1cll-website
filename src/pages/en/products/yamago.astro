---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const features = [
  {
    icon: '🗺️',
    title: 'Route Planning & Navigation',
    description: 'AI recommends optimal routes based on your fitness level. Dynamic difficulty ratings, escape route display, and automatic rerouting during weather changes keep you safe.',
  },
  {
    icon: '📍',
    title: 'Maps & GPS',
    description: 'Real-time location tracking, offline maps, 3D terrain visualization, and GPS noise filtering provide accurate navigation even in areas without cell service.',
  },
  {
    icon: '🆘',
    title: 'Safety & Emergency',
    description: 'One-tap SOS, hazard zone alerts, lightning and avalanche risk indicators, and altitude sickness monitoring. Be prepared for any emergency.',
  },
  {
    icon: '🌤️',
    title: 'Mountain Weather',
    description: 'Mountain-specific weather forecasts, barometer integration, rain radar, and weather-gear recommendations help you prepare for rapidly changing conditions.',
  },
  {
    icon: '💪',
    title: 'Fitness & Health',
    description: 'Calorie tracking, fatigue modeling, hydration reminders, and pace analysis. Monitor your physical condition in real time throughout your hike.',
  },
  {
    icon: '📝',
    title: 'Recording & Sharing',
    description: 'GPX import/export, auto-generated trip reports, timelapse videos, heatmaps, and PDF export to preserve and share your mountain memories.',
  },
  {
    icon: '👥',
    title: 'Community',
    description: 'Real-time location sharing, group dashboards, partner matching, and crowding information make group hiking safer and more enjoyable.',
  },
  {
    icon: '🧠',
    title: 'AI/ML Engine',
    description: 'AI route recommendations, ML fatigue prediction, ML risk assessment, and mountain chatbot. Cutting-edge machine learning optimizes your hiking experience.',
  },
];

const highlights = [
  {
    value: '130+',
    label: 'Modules',
    description: 'Large-scale application built as a PWA',
  },
  {
    value: '333',
    label: 'Tests',
    description: 'Comprehensive test suite ensuring quality',
  },
  {
    value: '8',
    label: 'Feature Categories',
    description: 'Covering every aspect of mountain hiking',
  },
];

const techStack = [
  { name: 'PWA', description: 'Progressive Web App' },
  { name: 'Firebase', description: 'Backend, Auth & Database' },
  { name: 'AI/ML', description: 'Route Recommendations, Risk & Fatigue' },
  { name: 'iOS / Android', description: 'Native apps planned' },
];
---

<Layout
  title="YAMAGO - The App for Mountain Goers"
  description="YAMAGO is a comprehensive mountain hiking platform with 130+ modules including route planning, GPS tracking, emergency SOS, mountain weather, and AI analysis. Make hiking more fun and safer."
  lang="en"
>
  <Header currentPath="/en/products/yamago" lang="en" />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content">
            <span class="badge">🏔️ Mountain Hiking Platform</span>
            <h1>YAMAGO</h1>
            <p class="tagline">The App for Mountain Goers</p>
            <p class="subtitle">Make hiking more fun and safer</p>
            <p class="description">
              A comprehensive platform covering everything from route planning to GPS tracking,
              emergency SOS, mountain weather, fitness management, and AI analysis.
              Built as a reliable PWA with 130+ modules and 333 tests.
            </p>
            <div class="hero-buttons">
              <a href="#features" class="btn btn-primary">
                View Features
              </a>
            </div>
          </div>

          <div class="hero-image">
            <div class="mountain-mockup">
              <div class="mountain-scene">
                <div class="sky">
                  <div class="cloud cloud-1"></div>
                  <div class="cloud cloud-2"></div>
                </div>
                <div class="mountains">
                  <div class="mountain mountain-back"></div>
                  <div class="mountain mountain-mid"></div>
                  <div class="mountain mountain-front"></div>
                </div>
                <div class="trail-overlay">
                  <svg viewBox="0 0 300 200" class="trail-svg">
                    <path d="M 20 180 Q 60 160 80 140 Q 100 120 130 100 Q 160 80 180 70 Q 210 55 240 30" fill="none" stroke="#ef4444" stroke-width="3" stroke-dasharray="8 4" stroke-linecap="round"/>
                    <circle cx="20" cy="180" r="5" fill="#22c55e"/>
                    <circle cx="240" cy="30" r="5" fill="#ef4444"/>
                    <circle cx="130" cy="100" r="4" fill="#f59e0b"/>
                  </svg>
                </div>
                <div class="app-overlay">
                  <div class="app-stat">
                    <span class="app-stat-value">9,340ft</span>
                    <span class="app-stat-label">Elevation</span>
                  </div>
                  <div class="app-status">
                    <span class="status-dot"></span>
                    <span>GPS Tracking</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Highlights -->
    <section class="section highlights">
      <div class="container">
        <div class="highlights-grid">
          {highlights.map(item => (
            <div class="highlight-card">
              <div class="highlight-value">{item.value}</div>
              <div class="highlight-label">{item.label}</div>
              <p>{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="section features">
      <div class="container">
        <div class="section-title">
          <h2>Features</h2>
          <p>Eight feature categories covering every aspect of mountain hiking</p>
        </div>

        <div class="features-grid">
          {features.map(feature => (
            <div class="feature-card">
              <div class="feature-icon">{feature.icon}</div>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="section tech">
      <div class="container">
        <div class="section-title">
          <h2>Tech Stack</h2>
          <p>Reliable architecture</p>
        </div>

        <div class="tech-grid">
          {techStack.map(tech => (
            <div class="tech-card">
              <h4>{tech.name}</h4>
              <p>{tech.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="section architecture">
      <div class="container">
        <div class="section-title">
          <h2>Architecture</h2>
          <p>A PWA platform composed of 130+ modules</p>
        </div>

        <div class="arch-diagram">
          <div class="arch-box main">
            <div class="arch-title">YAMAGO (PWA)</div>
            <div class="arch-children">
              <div class="arch-box">
                <div class="arch-title">Frontend</div>
                <div class="arch-items">
                  <span>Route Planning</span>
                  <span>3D Maps</span>
                  <span>Offline Support</span>
                </div>
              </div>
              <div class="arch-box">
                <div class="arch-title">AI/ML Engine</div>
                <div class="arch-items">
                  <span>Route Recommendations</span>
                  <span>Fatigue Prediction</span>
                  <span>Risk Assessment</span>
                </div>
              </div>
              <div class="arch-box">
                <div class="arch-title">Backend</div>
                <div class="arch-items">
                  <span>Firebase</span>
                  <span>GPS Processing</span>
                  <span>Weather Data</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section cta">
      <div class="container">
        <div class="cta-content">
          <h2>Make Hiking More Fun with YAMAGO</h2>
          <p>
            Experience safe and fulfilling mountain adventures
            with our AI-powered comprehensive hiking platform.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 4rem 0 6rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, #f0fdf4 100%);
  }

  :global([data-theme="dark"]) .hero {
    background: linear-gradient(180deg, var(--color-bg) 0%, #0a1f0a 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #16a34a, #15803d);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: 4rem;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, #16a34a, #ca8a04);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .tagline {
    font-size: 1.5rem;
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: #16a34a;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .description {
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero .btn-primary {
    background: linear-gradient(135deg, #16a34a, #15803d);
  }

  .hero .btn-primary:hover {
    background: linear-gradient(135deg, #15803d, #166534);
  }

  /* Mountain Mockup */
  .hero-image {
    display: flex;
    justify-content: center;
  }

  .mountain-mockup {
    width: 100%;
    max-width: 420px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
  }

  .mountain-scene {
    position: relative;
    width: 100%;
    height: 280px;
    background: linear-gradient(180deg, #7dd3fc 0%, #bae6fd 40%, #e0f2fe 70%);
    overflow: hidden;
  }

  :global([data-theme="dark"]) .mountain-scene {
    background: linear-gradient(180deg, #1e3a5f 0%, #0f2942 40%, #0c1e33 70%);
  }

  .sky {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
  }

  .cloud {
    position: absolute;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 50px;
    height: 16px;
  }

  :global([data-theme="dark"]) .cloud {
    background: rgba(255, 255, 255, 0.15);
  }

  .cloud-1 {
    width: 80px;
    top: 25%;
    left: 15%;
    animation: cloud-drift 20s ease-in-out infinite;
  }

  .cloud-2 {
    width: 60px;
    top: 15%;
    right: 20%;
    animation: cloud-drift 25s ease-in-out infinite reverse;
  }

  @keyframes cloud-drift {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(20px); }
  }

  .mountains {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 75%;
  }

  .mountain {
    position: absolute;
    bottom: 0;
    width: 0;
    height: 0;
    border-style: solid;
  }

  .mountain-back {
    left: 5%;
    border-width: 0 120px 160px 120px;
    border-color: transparent transparent #6b8e73 transparent;
  }

  :global([data-theme="dark"]) .mountain-back {
    border-color: transparent transparent #2d4a32 transparent;
  }

  .mountain-mid {
    left: 30%;
    border-width: 0 110px 190px 110px;
    border-color: transparent transparent #4a7c59 transparent;
  }

  :global([data-theme="dark"]) .mountain-mid {
    border-color: transparent transparent #1e3d25 transparent;
  }

  .mountain-front {
    right: 5%;
    border-width: 0 100px 150px 100px;
    border-color: transparent transparent #3d6b4e transparent;
  }

  :global([data-theme="dark"]) .mountain-front {
    border-color: transparent transparent #163320 transparent;
  }

  .trail-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
  }

  .trail-svg {
    width: 100%;
    height: 100%;
  }

  .app-overlay {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 12px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    z-index: 3;
  }

  .app-stat {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.75rem;
    display: flex;
    flex-direction: column;
  }

  .app-stat-value {
    color: white;
    font-weight: 700;
    font-size: 1.1rem;
  }

  .app-stat-label {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.7rem;
  }

  .app-status {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-md);
    padding: 0.4rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: white;
    font-size: 0.75rem;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero h1 {
      font-size: 3rem;
    }

    .hero-buttons {
      justify-content: center;
    }

    .hero-image {
      order: -1;
    }
  }

  /* Highlights */
  .highlights {
    background-color: var(--color-bg);
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .highlight-card {
    text-align: center;
    padding: 2rem;
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .highlight-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .highlight-value {
    font-size: 3rem;
    font-weight: 800;
    background: linear-gradient(135deg, #16a34a, #ca8a04);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.25rem;
  }

  .highlight-label {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .highlight-card p {
    color: var(--color-text-light);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .highlights-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Features */
  .features {
    background-color: var(--color-bg-alt);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .feature-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }

  .feature-card p {
    color: var(--color-text-light);
    line-height: 1.7;
    font-size: 0.9rem;
  }

  @media (max-width: 960px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Tech */
  .tech {
    background-color: var(--color-bg);
  }

  .tech-grid {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .tech-card {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem 2rem;
    text-align: center;
    min-width: 200px;
  }

  .tech-card h4 {
    color: #16a34a;
    margin-bottom: 0.5rem;
  }

  .tech-card p {
    color: var(--color-text-light);
    font-size: 0.875rem;
  }

  /* Architecture */
  .architecture {
    background: linear-gradient(180deg, #1a2e1a 0%, #0f1f0f 100%);
    color: white;
  }

  .architecture .section-title h2 {
    color: white;
  }

  .architecture .section-title p {
    color: rgba(255, 255, 255, 0.8);
  }

  .arch-diagram {
    max-width: 800px;
    margin: 0 auto;
  }

  .arch-box {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .arch-box.main {
    padding: 2rem;
  }

  .arch-title {
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: #4ade80;
  }

  .arch-children {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .arch-items {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .arch-items span {
    background: rgba(255, 255, 255, 0.1);
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 768px) {
    .arch-children {
      grid-template-columns: 1fr;
    }
  }

  /* CTA */
  .cta {
    background: linear-gradient(135deg, #16a34a, #ca8a04);
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta h2 {
    color: white;
    margin-bottom: 1rem;
  }

  .cta p {
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
    line-height: 1.8;
  }
</style>
