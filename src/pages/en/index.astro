---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const features = [
  {
    icon: '🤖',
    title: 'AI Coach',
    description: 'Personalized advice to help you achieve your goals',
  },
  {
    icon: '📸',
    title: 'Auto Log Import',
    description: 'Automatically recognize running data from screenshots',
  },
  {
    icon: '📅',
    title: 'Training Plans',
    description: 'Auto-generated weekly plans for efficient training',
  },
  {
    icon: '🎯',
    title: 'Pacing Strategy',
    description: 'Optimal pace distribution for your goal race',
  },
];
---

<Layout 
  title="Home" 
  description="Creative Life Labo - Developing apps and services to enhance your lifestyle. Featuring Run Diary, an AI-powered running journal app."
  lang="en"
>
  <Header currentPath="/en/" lang="en" />
  
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <h1 class="hero-title">
            Enhance Your<br />
            <span class="gradient-text">Lifestyle with Technology</span>
          </h1>
          <p class="hero-description">
            Creative Life Labo develops apps and services to enrich your daily life.
            We support your goal achievement with smart solutions powered by AI.
          </p>
          <div class="hero-buttons">
            <a href="#products" class="btn btn-primary">
              View Products
            </a>
            <a href="/en/about" class="btn btn-secondary">
              About Us
            </a>
          </div>
        </div>
      </div>
      <div class="hero-bg"></div>
    </section>
    
    <!-- Products Section -->
    <section id="products" class="section products">
      <div class="container">
        <div class="section-title">
          <h2>Products</h2>
          <p>Apps and services we've developed</p>
        </div>

        <div class="product-card ados-card">
          <div class="product-content">
            <span class="product-badge ados-badge">AI DevOps Platform</span>
            <h3 class="product-title">ADOS</h3>
            <p class="product-subtitle">AI DevOps as a Service</p>
            <p class="product-description">
              AI coding agents automatically process GitHub Issues and orchestrate
              the entire workflow up to creating Pull Requests. A development operations
              platform that centrally manages everything from multi-repository monitoring
              to AI execution.
            </p>

            <div class="product-features">
              <div class="mini-feature">
                <span class="mini-feature-icon">🔄</span>
                <div>
                  <strong>Multi-Repository</strong>
                  <p>Monitor multiple repos from a single process</p>
                </div>
              </div>
              <div class="mini-feature">
                <span class="mini-feature-icon">🤖</span>
                <div>
                  <strong>Multi-AI Agent</strong>
                  <p>Auto-switch between Copilot / Claude / Codex</p>
                </div>
              </div>
              <div class="mini-feature">
                <span class="mini-feature-icon">📅</span>
                <div>
                  <strong>Scheduled Tasks</strong>
                  <p>Automate recurring tasks with cron</p>
                </div>
              </div>
              <div class="mini-feature">
                <span class="mini-feature-icon">🔍</span>
                <div>
                  <strong>SRE Agent</strong>
                  <p>Cloud log monitoring & auto-repair</p>
                </div>
              </div>
            </div>

            <div class="product-buttons">
              <a href="/en/products/ados" class="btn btn-primary">
                Learn More
              </a>
              <a href="https://ados.dev" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
                ados.dev →
              </a>
            </div>
          </div>

          <div class="product-visual">
            <div class="terminal-preview">
              <div class="terminal-preview-header">
                <div class="terminal-preview-dots">
                  <span class="tdot red"></span>
                  <span class="tdot yellow"></span>
                  <span class="tdot green"></span>
                </div>
                <span class="terminal-preview-title">ados</span>
              </div>
              <div class="terminal-preview-body">
                <div class="tline"><span class="tprompt">$</span> ados start --config ados.yaml</div>
                <div class="tline"><span class="ttime">09:00:01</span> <span class="tinfo">INFO</span> Watching 5 repositories...</div>
                <div class="tline"><span class="ttime">09:00:15</span> <span class="tinfo">INFO</span> Issue #42 detected in myapp</div>
                <div class="tline"><span class="ttime">09:00:16</span> <span class="tagent">AGENT</span> Claude Code processing...</div>
                <div class="tline"><span class="ttime">09:02:33</span> <span class="tagent">AGENT</span> Running tests...</div>
                <div class="tline"><span class="ttime">09:03:10</span> <span class="tinfo">INFO</span> All 47 tests passed</div>
                <div class="tline"><span class="ttime">09:03:42</span> <span class="tok">OK</span> PR #43 created successfully</div>
                <div class="tline"><span class="ttime">09:05:01</span> <span class="tinfo">INFO</span> Issue #44 detected in api-srv</div>
                <div class="tline"><span class="ttime">09:05:02</span> <span class="tagent">AGENT</span> Copilot processing...</div>
              </div>
            </div>
          </div>
        </div>

        <div class="product-spacer"></div>

        <div class="product-card">
          <div class="product-content">
            <span class="product-badge">Running App</span>
            <h3 class="product-title">Run Diary</h3>
            <p class="product-subtitle">AI-Powered Running Journal</p>
            <p class="product-description">
              A running journal app powered by Google Gemini AI.
              Features include automatic log import from screenshots, auto-generated weekly training plans,
              and pacing strategies for your goal race. Perfect for runners aiming to complete a marathon
              or achieve sub-4/sub-3 goals.
            </p>
            
            <div class="product-features">
              {features.map(feature => (
                <div class="mini-feature">
                  <span class="mini-feature-icon">{feature.icon}</span>
                  <div>
                    <strong>{feature.title}</strong>
                    <p>{feature.description}</p>
                  </div>
                </div>
              ))}
            </div>
            
            <a href="/en/products/run-diary" class="btn btn-primary">
              Learn More
            </a>
          </div>
          
          <div class="product-visual">
            <div class="phone-mockup">
              <div class="phone-screen">
                <div class="screen-header">
                  <span class="time">9:41</span>
                </div>
                <div class="app-ui">
                  <div class="app-nav">
                    <span>🏃</span>
                    <span class="app-title">Run Diary</span>
                    <span>⚙️</span>
                  </div>
                  <div class="run-card">
                    <div class="run-date">Jan 8, 2026 (Wed)</div>
                    <div class="run-stats">
                      <div class="stat">
                        <div class="stat-value">10.5</div>
                        <div class="stat-label">km</div>
                      </div>
                      <div class="stat">
                        <div class="stat-value">52:30</div>
                        <div class="stat-label">time</div>
                      </div>
                      <div class="stat">
                        <div class="stat-value">5:00</div>
                        <div class="stat-label">/km</div>
                      </div>
                    </div>
                  </div>
                  <div class="weekly-bar">
                    <div class="weekly-label">Weekly mileage</div>
                    <div class="weekly-progress">
                      <div class="weekly-fill"></div>
                    </div>
                    <div class="weekly-text">32.5 / 50 km</div>
                  </div>
                  <div class="ai-chat">
                    <div class="ai-avatar">🤖</div>
                    <div class="ai-message">
                      <p>Great run! Your pace of 5:00/km is right on target. Try pushing to 4:50/km next time!</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="product-spacer"></div>

        <div class="product-card yamago-card">
          <div class="product-content">
            <span class="product-badge yamago-badge">Mountain Hiking Platform</span>
            <h3 class="product-title">YAMAGO</h3>
            <p class="product-subtitle">The App for Mountain Goers</p>
            <p class="product-description">
              A comprehensive platform covering everything from route planning to GPS tracking,
              emergency SOS, mountain weather, fitness management, and AI analysis.
              Built as a reliable PWA with 130+ modules and 333 tests.
            </p>

            <div class="product-features">
              <div class="mini-feature">
                <span class="mini-feature-icon">🗺️</span>
                <div>
                  <strong>AI Route Planning</strong>
                  <p>Optimal routes based on your fitness</p>
                </div>
              </div>
              <div class="mini-feature">
                <span class="mini-feature-icon">🆘</span>
                <div>
                  <strong>Safety & Emergency</strong>
                  <p>One-tap SOS & hazard zone alerts</p>
                </div>
              </div>
              <div class="mini-feature">
                <span class="mini-feature-icon">🌤️</span>
                <div>
                  <strong>Mountain Weather</strong>
                  <p>Mountain-specific forecasts & gear tips</p>
                </div>
              </div>
              <div class="mini-feature">
                <span class="mini-feature-icon">🧠</span>
                <div>
                  <strong>AI/ML Engine</strong>
                  <p>Fatigue prediction & risk assessment</p>
                </div>
              </div>
            </div>

            <div class="product-buttons">
              <a href="/en/products/yamago" class="btn btn-primary yamago-btn">
                Learn More
              </a>
            </div>
          </div>

          <div class="product-visual">
            <div class="mountain-preview">
              <div class="mountain-preview-scene">
                <div class="mp-sky">
                  <div class="mp-cloud mp-cloud-1"></div>
                  <div class="mp-cloud mp-cloud-2"></div>
                  <div class="mp-cloud mp-cloud-3"></div>
                </div>
                <svg class="mp-scene-svg" viewBox="0 0 360 220" preserveAspectRatio="xMidYMax slice">
                  <path d="M -20 220 L 60 70 Q 75 50 90 65 L 120 95 Q 130 80 140 85 L 200 220 Z" fill="#6b8e73"/>
                  <path d="M 60 70 Q 75 50 90 65 L 85 75 Q 75 60 68 72 Z" fill="white" opacity="0.7"/>
                  <path d="M 80 220 L 170 35 Q 185 15 200 30 L 220 55 Q 230 45 240 50 L 300 220 Z" fill="#4a7c59"/>
                  <path d="M 170 35 Q 185 15 200 30 L 195 42 Q 185 25 175 38 Z" fill="white" opacity="0.8"/>
                  <path d="M 220 55 Q 225 48 230 50 L 228 56 Z" fill="white" opacity="0.5"/>
                  <path d="M 200 220 L 280 75 Q 295 55 310 70 L 330 95 Q 340 88 350 92 L 380 220 Z" fill="#3d6b4e"/>
                  <path d="M 280 75 Q 295 55 310 70 L 305 80 Q 295 62 285 78 Z" fill="white" opacity="0.7"/>
                  <path d="M 20 210 L 25 190 L 22 192 L 27 178 L 24 180 L 28 170 L 32 180 L 29 178 L 34 192 L 31 190 L 35 210 Z" fill="#2d5a3a" opacity="0.7"/>
                  <path d="M 45 215 L 49 198 L 47 200 L 51 188 L 49 190 L 52 182 L 55 190 L 53 188 L 57 200 L 55 198 L 58 215 Z" fill="#2d5a3a" opacity="0.6"/>
                  <path d="M 320 215 L 324 200 L 322 202 L 326 192 L 324 194 L 327 186 L 330 194 L 328 192 L 332 202 L 330 200 L 334 215 Z" fill="#1e4a2e" opacity="0.7"/>
                  <path d="M 340 218 L 343 205 L 341 207 L 345 198 L 348 207 L 346 205 L 349 218 Z" fill="#1e4a2e" opacity="0.5"/>
                  <path d="M 15 205 Q 50 180 80 155 Q 110 130 140 110 Q 170 90 195 70 Q 215 55 240 35" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-dasharray="6 3" stroke-linecap="round"/>
                  <circle cx="15" cy="205" r="4" fill="#22c55e"/>
                  <circle cx="140" cy="110" r="3.5" fill="#f59e0b"/>
                  <circle cx="240" cy="35" r="4" fill="#ef4444"/>
                </svg>
                <div class="mp-overlay">
                  <div class="mp-stat">
                    <span class="mp-stat-val">9,340ft</span>
                  </div>
                  <div class="mp-gps">
                    <span class="mp-gps-dot"></span>
                    GPS
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Client Work Section -->
    <section class="section client-work">
      <div class="container">
        <div class="section-title">
          <h2>Client Projects</h2>
          <p>Projects we've delivered for our clients</p>
        </div>

        <div class="client-grid">
          <div class="client-card">
            <div class="client-icon">🪪</div>
            <h3>JAC Member Card App</h3>
            <p class="client-org">Japanese Alpine Club</p>
            <p class="client-desc">Digital membership card with QR code authentication and member benefit search for the Japanese Alpine Club.</p>
            <div class="client-tech">
              <span>Next.js</span>
              <span>Firebase</span>
              <span>Tailwind CSS</span>
            </div>
          </div>

          <div class="client-card">
            <div class="client-icon">👥</div>
            <h3>JAC Youth Club Manager</h3>
            <p class="client-org">JAC Youth Club</p>
            <p class="client-desc">Membership approval workflow with Google Group integration for the Japanese Alpine Club Youth Club.</p>
            <div class="client-tech">
              <span>Next.js</span>
              <span>Firebase</span>
              <span>Google API</span>
            </div>
          </div>

          <div class="client-card">
            <div class="client-icon">📋</div>
            <h3>Tax Filing Manager</h3>
            <p class="client-org">Freelancers</p>
            <p class="client-desc">Tax return data management and expense automation with GitHub Issue-based task tracking.</p>
            <div class="client-tech">
              <span>GitHub API</span>
              <span>Automation</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section cta">
      <div class="container">
        <div class="cta-content">
          <h2>Start Your Running Journey</h2>
          <p>Create a free account and start training with your AI coach.</p>
          <a href="https://run-diary-2026.web.app" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
            Try Run Diary Free
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer lang="en" />
</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: 6rem 0;
    overflow: hidden;
  }
  
  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.05) 0%, rgba(139, 92, 246, 0.05) 100%);
    z-index: -1;
  }
  
  .hero-content {
    max-width: 640px;
  }
  
  .hero-title {
    font-size: 3.5rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  
  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary) 0%, #8B5CF6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .hero-description {
    font-size: 1.25rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  
  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  /* Products */
  .products {
    background-color: var(--color-bg-alt);
  }
  
  .section-title {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .section-title h2 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  
  .section-title p {
    color: var(--color-text-light);
  }
  
  .product-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 3rem;
  }
  
  .product-badge {
    display: inline-block;
    background: linear-gradient(135deg, var(--color-primary) 0%, #8B5CF6 100%);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .product-title {
    font-size: 2.5rem;
    margin: 1rem 0 0.5rem;
  }
  
  .product-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }
  
  .product-description {
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }
  
  .product-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  
  .mini-feature {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }
  
  .mini-feature-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  
  .mini-feature strong {
    font-size: 0.875rem;
    display: block;
    margin-bottom: 0.25rem;
  }
  
  .mini-feature p {
    font-size: 0.8125rem;
    color: var(--color-text-light);
    line-height: 1.4;
  }
  
  /* Product Spacer */
  .product-spacer {
    height: 3rem;
  }

  /* Product Buttons */
  .product-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ADOS Badge */
  .ados-badge {
    background: linear-gradient(135deg, var(--color-primary), #8B5CF6);
  }

  /* Terminal Preview (ADOS) */
  .terminal-preview {
    width: 100%;
    max-width: 420px;
    background: #1e1e2e;
    border-radius: var(--radius-lg);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25), 0 0 40px rgba(139, 92, 246, 0.15);
    overflow: hidden;
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .terminal-preview-header {
    padding: 0.6rem 0.75rem;
    background: #181825;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .terminal-preview-dots {
    display: flex;
    gap: 0.4rem;
  }

  .terminal-preview-title {
    color: #6c7086;
    font-size: 0.7rem;
    font-weight: 500;
  }

  .tdot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .tdot.red { background: #f38ba8; }
  .tdot.yellow { background: #f9e2af; }
  .tdot.green { background: #a6e3a1; }

  .terminal-preview-body {
    padding: 1rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.72rem;
    line-height: 1.8;
  }

  .tline {
    color: #bac2de;
  }

  .tprompt {
    color: #a6e3a1;
    font-weight: 700;
  }

  .ttime {
    color: #6c7086;
  }

  .tinfo {
    color: #89b4fa;
    font-weight: 600;
  }

  .tagent {
    color: #cba6f7;
    font-weight: 600;
  }

  .tok {
    color: #a6e3a1;
    font-weight: 600;
  }

  /* Phone Mockup */
  .product-visual {
    display: flex;
    justify-content: center;
  }

  .phone-mockup {
    width: 280px;
    height: 560px;
    background: #1a1a1a;
    border-radius: 40px;
    padding: 12px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    background: #0f172a;
    border-radius: 30px;
    overflow: hidden;
  }

  .screen-header {
    padding: 0.5rem 1rem;
    text-align: center;
  }

  .time {
    font-size: 0.8rem;
    font-weight: 600;
    color: white;
  }

  .app-ui {
    padding: 0 0.75rem 0.75rem;
  }

  .app-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    color: white;
  }

  .app-title {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .run-card {
    background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
    border-radius: 12px;
    padding: 0.75rem;
    color: white;
    margin-bottom: 0.6rem;
  }

  .run-date {
    font-size: 0.65rem;
    opacity: 0.9;
    margin-bottom: 0.5rem;
  }

  .run-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    text-align: center;
  }

  .stat {
    text-align: center;
  }

  .stat-value {
    font-size: 1.25rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 0.6rem;
    opacity: 0.8;
  }

  .weekly-bar {
    background: rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    padding: 0.6rem 0.75rem;
    margin-bottom: 0.6rem;
  }

  .weekly-label {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.6rem;
    margin-bottom: 0.3rem;
  }

  .weekly-progress {
    height: 5px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 3px;
    margin-bottom: 0.25rem;
  }

  .weekly-fill {
    width: 65%;
    height: 100%;
    background: linear-gradient(90deg, #3b82f6, #10b981);
    border-radius: 3px;
  }

  .weekly-text {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.6rem;
    font-weight: 600;
  }

  .ai-chat {
    display: flex;
    gap: 0.5rem;
  }

  .ai-avatar {
    width: 32px;
    height: 32px;
    background: rgba(59, 130, 246, 0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .ai-message {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 0.6rem;
    font-size: 0.7rem;
    color: white;
    line-height: 1.4;
  }
  
  /* YAMAGO Badge */
  .yamago-badge {
    background: linear-gradient(135deg, #16a34a, #ca8a04);
  }

  .yamago-btn {
    background: linear-gradient(135deg, #16a34a, #15803d);
  }

  .yamago-btn:hover {
    background: linear-gradient(135deg, #15803d, #166534);
  }

  /* Mountain Preview (YAMAGO) */
  .mountain-preview {
    width: 100%;
    max-width: 360px;
    border-radius: var(--radius-lg);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    overflow: hidden;
  }

  .mountain-preview-scene {
    position: relative;
    width: 100%;
    height: 240px;
    background: linear-gradient(180deg, #7dd3fc 0%, #bae6fd 40%, #e0f2fe 70%);
    overflow: hidden;
  }

  .mp-sky {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
  }

  .mp-cloud {
    position: absolute;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 50px;
    height: 12px;
  }

  .mp-cloud-1 {
    width: 60px;
    top: 25%;
    left: 15%;
